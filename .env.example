# ══════════════════════════════════════════════════════════════════
#  AlphaGrid v6 — Environment file
#  Copy to .env: cp .env.example .env
#  The server starts fine with ALL values empty (paper trading mode)
# ══════════════════════════════════════════════════════════════════

# JWT secret — generate one with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# Leave empty to auto-generate (changes on every restart = sessions reset)
ALPHAGRID_JWT_SECRET=

# ── Alpaca (free paper trading at alpaca.markets) ─────────────────
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── OANDA (free demo at oanda.com) ────────────────────────────────
OANDA_API_KEY=
OANDA_ACCOUNT_ID=

# ── Robinhood ─────────────────────────────────────────────────────
ROBINHOOD_USERNAME=
ROBINHOOD_PASSWORD=
ROBINHOOD_MFA_SECRET=

# ── NewsAPI (free 100 req/day at newsapi.org) ─────────────────────
NEWS_API_KEY=

# ── Reddit (free at reddit.com/prefs/apps) ────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
