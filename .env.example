# ══════════════════════════════════════════════════════════════════
#  AlphaGrid v7 — Environment file
#  Copy to .env: cp .env.example .env
#  The server starts fine with ALL values empty (paper trading mode)
# ══════════════════════════════════════════════════════════════════

# JWT secret — generate one with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# Leave empty to auto-generate (changes on every restart = sessions reset)
ALPHAGRID_JWT_SECRET=

# ── Auth credentials ──────────────────────────────────────────────────────────
# Default values are used if not set. Change these before any shared/cloud deployment.
ALPHAGRID_OWNER_USERNAME=admin
ALPHAGRID_OWNER_PASSWORD=Admin@Grid1
ALPHAGRID_OWNER_EMAIL=owner@alphagrid.app
ALPHAGRID_BUILDER_PASSWORD=Builder1!
ALPHAGRID_TRADER_PASSWORD=Trader1!

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or * for local development.
# Example for production: ALPHAGRID_CORS_ORIGINS=https://yourdomain.com
ALPHAGRID_CORS_ORIGINS=*

# ── Alpaca (free at alpaca.markets — paper trading + real-time IEX feed) ──────
# Sign up free → alpaca.markets → Paper Trading → API Keys
# Gives real-time WebSocket prices for top 30 US equities (10–50ms latency).
# Without these keys the server runs fine — yfinance covers all symbols.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── OANDA (free demo at oanda.com) ────────────────────────────────
OANDA_API_KEY=
OANDA_ACCOUNT_ID=

# ── Robinhood ─────────────────────────────────────────────────────
ROBINHOOD_USERNAME=
ROBINHOOD_PASSWORD=
ROBINHOOD_MFA_SECRET=

# ── NewsAPI (free 100 req/day at newsapi.org) ─────────────────────
NEWS_API_KEY=

# ── Reddit (free at reddit.com/prefs/apps) ────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
